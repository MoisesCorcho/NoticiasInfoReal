<IfModule mod_rewrite.c>
    RewriteEngine On
    RewriteBase /

    # SECURITY: Block access to sensitive files/directories
    RewriteRule ^(\.env|\.git|composer\.(json|lock)|auth\.json|package\.(json|lock)|artisan|phpunit\.xml)$ - [F,L]
    RewriteRule ^(storage|resources|database)/ - [F,L]

    # Redirect everything to the public folder
    RewriteRule ^(.*)$ public/$1 [L]
</IfModule>